# Automatic HTTPS via Let's Encrypt — just point the domain at this server.
# {$DOMAIN} comes from the .env file (e.g. dagcrm.com).
{$DOMAIN}, www.{$DOMAIN} {
	encode gzip

	# AI microservice — strip the /ai prefix so /ai/score/lead -> /score/lead
	handle_path /ai/* {
		reverse_proxy ai-service:8100
	}

	# Django REST API (keeps the /api prefix that Django expects)
	handle /api/* {
		reverse_proxy backend:8000
	}

	# Django admin
	handle /admin/* {
		reverse_proxy backend:8000
	}

	# Django static (admin / DRF) and uploaded files (resumes, attachments)
	handle_path /static/* {
		root * /srv/static
		file_server
	}
	handle_path /media/* {
		root * /srv/media
		file_server
	}

	# Hashed build assets. Content-addressed, so cache them hard — but a miss MUST
	# 404 instead of falling through to the SPA handler: a browser holding a stale
	# index.html asks for a bundle the last deploy deleted, and answering with HTML
	# makes it parse a page as JavaScript, which blanks the whole app.
	handle /assets/* {
		root * /srv/frontend
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# Everything else = the React single-page app. index.html must be revalidated
	# on every load so a deploy's new asset hashes are picked up straight away.
	handle {
		root * /srv/frontend
		header Cache-Control "no-cache"
		try_files {path} /index.html
		file_server
	}
}
