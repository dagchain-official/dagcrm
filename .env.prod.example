# Copy this to `.env.prod` on the server and fill in real values.
# NEVER commit the real .env.prod (it holds secrets).

# Your domain (no http://, no www — Caddy adds www automatically)
DOMAIN=dagcrm.com

# Django secret — generate a long random string (see deploy guide)
SECRET_KEY=CHANGE_ME_to_a_long_random_string

# Postgres database credentials (pick a strong password)
POSTGRES_DB=dagos
POSTGRES_USER=dagos
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
